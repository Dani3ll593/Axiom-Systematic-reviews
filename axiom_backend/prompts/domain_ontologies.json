{
  "_schema_version": "1.0",
  "_description": "Domain ontologies for the extractor. Maps a user-facing 'domain' string (from initial_state) to a bucket, where each bucket defines the closed set of allowed values for variables[].type in PaperExtraction. Editing this file does NOT require touching Python — extractor.py reads it via prompts/__init__.py on backend startup.",
  "_maintenance_rules": [
    "Every bucket MUST include 'other' as escape hatch.",
    "'default' bucket MUST exist (used when domain doesn't match any entry in domain_to_bucket_map).",
    "Every value in domain_to_bucket_map MUST exist as a key in buckets.",
    "Keys in domain_to_bucket_map are matched after normalization: lowercase + strip + spaces/hyphens -> underscores.",
    "Removing values from a bucket can break analysis of older runs whose extractions are on disk — only add, never remove unless audited."
  ],

  "buckets": {
    "health": [
      "intervention",
      "comparator",
      "exposure",
      "outcome",
      "covariate",
      "confounder",
      "mediator",
      "moderator",
      "demographic",
      "other"
    ],
    "social": [
      "independent",
      "dependent",
      "mediator",
      "moderator",
      "covariate",
      "demographic",
      "confounder",
      "predictor",
      "other"
    ],
    "it_cs": [
